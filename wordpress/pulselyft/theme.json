{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "768px",
			"wideSize": "1152px"
		},
		"color": {
			"custom": true,
			"customGradient": true,
			"defaultPalette": false,
			"palette": [
				{ "slug": "ink", "color": "#0f0f10", "name": "Ink" },
				{ "slug": "page", "color": "#f5f4f0", "name": "Page" },
				{ "slug": "paper", "color": "#ffffff", "name": "Paper" },
				{ "slug": "lift", "color": "#65a30d", "name": "Lift" },
				{ "slug": "lift-bright", "color": "#84cc16", "name": "Lift Bright" },
				{ "slug": "lift-soft", "color": "#ecfccb", "name": "Lift Soft" },
				{ "slug": "zinc-600", "color": "#52525b", "name": "Muted" }
			]
		},
		"typography": {
			"customFontSize": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Outfit\", system-ui, sans-serif",
					"slug": "sans",
					"name": "Outfit (Sans)"
				},
				{
					"fontFamily": "\"Fraunces\", Georgia, serif",
					"slug": "display",
					"name": "Fraunces (Display)"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small" },
				{ "slug": "medium", "size": "1.125rem", "name": "Medium" },
				{ "slug": "large", "size": "1.5rem", "name": "Large" },
				{ "slug": "x-large", "size": "2.25rem", "name": "Extra Large" }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		}
	},
	"styles": {
		"color": {
			"background": "#f5f4f0",
			"text": "#27272a"
		},
		"typography": {
			"fontFamily": "\"Outfit\", system-ui, sans-serif",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": { "text": "#65a30d" }
			},
			"h1": { "typography": { "fontFamily": "\"Fraunces\", Georgia, serif", "fontWeight": "500" } },
			"h2": { "typography": { "fontFamily": "\"Fraunces\", Georgia, serif", "fontWeight": "500" } },
			"h3": { "typography": { "fontFamily": "\"Fraunces\", Georgia, serif", "fontWeight": "500" } }
		}
	}
}
